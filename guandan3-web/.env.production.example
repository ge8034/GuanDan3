# 生产环境配置示例
# 请复制此文件为 .env.production.local 并填入实际值

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 应用配置
NEXT_PUBLIC_APP_URL=https://guandan3.com
NEXT_PUBLIC_APP_NAME=掼蛋3
NEXT_PUBLIC_APP_VERSION=1.0.0

# 监控配置
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# Sentry 错误监控
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=guandan3
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# 功能开关
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_ANIMATIONS=true
NEXT_PUBLIC_ENABLE_SOUND=true
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_AI=true

# 性能配置
NEXT_PUBLIC_MAX_CONCURRENT_USERS=1000
NEXT_PUBLIC_WEBSOCKET_TIMEOUT=30000
NEXT_PUBLIC_RECONNECT_INTERVAL=5000

# 安全配置
NEXT_PUBLIC_ENABLE_CSP=true
NEXT_PUBLIC_ENABLE_HSTS=true
NEXT_PUBLIC_ENABLE_XSS_PROTECTION=true

# 缓存配置
NEXT_PUBLIC_CACHE_ENABLED=true
NEXT_PUBLIC_CACHE_TTL=3600
NEXT_PUBLIC_STATIC_CACHE_TTL=31536000

# 日志配置
NEXT_PUBLIC_LOG_LEVEL=error
NEXT_PUBLIC_LOG_TO_CONSOLE=false

# API 配置
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_API_RETRY_ATTEMPTS=3
NEXT_PUBLIC_API_RETRY_DELAY=1000

# 数据库配置
DATABASE_POOL_SIZE=20
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_QUERY_TIMEOUT=5000

# 实时配置
REALTIME_MAX_CONNECTIONS=1000
REALTIME_MESSAGE_SIZE_LIMIT=1048576
REALTIME_PING_INTERVAL=25000

# 存储配置
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,audio/mp3,audio/wav
