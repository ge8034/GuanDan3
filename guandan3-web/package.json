{
  "name": "guandan3-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest",
    "test:components": "vitest run src/test/component-loading.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:perf": "node scripts/run-perf.js",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "node scripts/load-test-node.js",
    "test:load:k6": "k6 run k6/load-test.js",
    "test:load:summary": "k6 run --summary-export=k6-summary.json k6/load-test.js",
    "perf:baseline": "node scripts/establish-baseline.js",
    "perf:test": "node scripts/run-performance-tests.js",
    "perf:report": "node scripts/generate-performance-report.js",
    "test:ai": "npm run test:ai:unit && npm run test:ai:integration && npm run test:ai:e2e",
    "test:ai:unit": "vitest src/test/unit/game/ai-*.test.ts",
    "test:ai:integration": "vitest src/test/integration/ai/*.test.ts",
    "test:ai:e2e": "playwright tests/e2e/ai/*.spec.ts",
    "test:ai:coverage": "vitest src/test/unit/game/ai-*.test.ts --coverage",
    "test:ai:ci": "vitest src/test/unit/game/ai-*.test.ts --run && playwright tests/e2e/ai/*.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "migrate": "node --loader ts-node/esm scripts/smart-migrate.ts",
    "migrate:validate": "node --loader ts-node/esm scripts/smart-migrate.ts validate",
    "migrate:apply": "node --loader ts-node/esm scripts/smart-migrate.ts apply",
    "migrate:status": "node --loader ts-node/esm scripts/smart-migrate.ts status",
    "migrate:all": "node --loader ts-node/esm scripts/smart-migrate.ts apply --all",
    "migrate:dry-run": "node --loader ts-node/esm scripts/smart-migrate.ts apply --dry-run",
    "migrate:test": "vitest run src/test/migration --reporter=verbose",
    "migrate:test:coverage": "vitest run src/test/migration --coverage"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/supabase-js": "^2.99.1",
    "@types/crypto-js": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-pwa": "^5.6.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.1.6",
    "inquirer": "^9.2.12",
    "jest-axe": "^10.0.0",
    "jsdom": "^28.1.0",
    "ora": "^8.0.1",
    "postcss": "^8.5.8",
    "storybook": "^10.3.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
