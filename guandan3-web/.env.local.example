# Supabase 配置
# 获取方式：访问 https://supabase.com/dashboard -> Project Settings -> API

# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名公钥（anon key）
# 用于客户端访问，具有 RLS 保护的权限
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 注意事项：
# 1. 不要提交真实的密钥到版本控制系统
# 2. 本文件仅作为模板，实际使用时复制为 .env.local 并填入真实值
# 3. .env.local 已在 .gitignore 中，不会被提交
